page {
  min-height: 100%;
  background: #f5f7fb;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(16, 24, 40, 0.06);
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #101828;
}

.subtitle {
  font-size: 26rpx;
  color: #667085;
  margin-top: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.input,
.picker-like,
.textarea {
  width: 100%;
  min-height: 80rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f2f4f7;
  padding: 18rpx 22rpx;
  color: #101828;
}

.textarea {
  min-height: 140rpx;
}

.label {
  font-size: 24rpx;
  color: #667085;
  margin-bottom: 10rpx;
}

.field {
  margin-bottom: 20rpx;
}

.btn {
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 28rpx;
  border: 0;
}

.btn-primary {
  background: #2563eb;
  color: #ffffff;
}

.btn-secondary {
  background: #e8f0ff;
  color: #1d4ed8;
}

.btn-danger {
  background: #fff1f3;
  color: #d92d20;
}

.btn-ghost {
  background: transparent;
  color: #2563eb;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  background: #eef2ff;
  color: #344054;
  font-size: 24rpx;
}

.chip.active {
  background: #2563eb;
  color: #ffffff;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.metric {
  background: #f8fafc;
  border-radius: 22rpx;
  padding: 22rpx;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 800;
}

.metric-label {
  font-size: 24rpx;
  color: #667085;
  margin-top: 8rpx;
}

.muted {
  color: #667085;
}
