.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(16, 24, 40, 0.45);
  z-index: 99;
  display: flex;
  align-items: flex-end;
}
.panel {
  width: 100%;
  max-height: 78vh;
  background: #fff;
  border-radius: 34rpx 34rpx 0 0;
  padding: 28rpx;
  box-sizing: border-box;
}
.head { margin-bottom: 20rpx; }
.row { display: flex; align-items: center; }
.between { justify-content: space-between; }
.panel-title { font-size: 34rpx; font-weight: 800; }
.close { color: #2563eb; font-size: 26rpx; }
.search {
  height: 82rpx;
  background: #f2f4f7;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
}
.list { max-height: 58vh; }
.group-title { color: #667085; font-size: 24rpx; margin: 10rpx 0 4rpx; }
.all-title { margin-top: 18rpx; }
.item {
  padding: 22rpx 4rpx;
  border-bottom: 1rpx solid #eaecf0;
}
.item.favorite { background: #fffbeb; border-radius: 18rpx; padding-left: 18rpx; padding-right: 18rpx; margin-bottom: 10rpx; border-bottom: 0; }
.item-name { font-size: 30rpx; font-weight: 700; }
.item-meta { margin-top: 8rpx; font-size: 24rpx; color: #667085; }
.favorite-mark { color: #c2410c; background: #ffedd5; border-radius: 999rpx; padding: 8rpx 14rpx; font-size: 22rpx; }
