.search { margin-top: 22rpx; }
.h-scroll { white-space: nowrap; margin-top: 16rpx; }
.filter-row { display: flex; gap: 12rpx; }
.exercise-card { display: flex; padding: 0; overflow: hidden; }
.exercise-image { width: 210rpx; min-height: 220rpx; background: #f2f4f7; flex: none; }
.exercise-body { padding: 22rpx; min-width: 0; }
.exercise-name { font-size: 31rpx; font-weight: 800; }
.exercise-en { margin-top: 5rpx; color: #667085; font-size: 22rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.meta { margin-top: 14rpx; color: #2563eb; font-size: 23rpx; }
.steps { margin-top: 12rpx; color: #475467; font-size: 23rpx; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.attribution { margin-top: 12rpx; color: #98a2b3; font-size: 18rpx; }
.loading-more { padding: 28rpx; text-align: center; color: #98a2b3; font-size: 23rpx; }
