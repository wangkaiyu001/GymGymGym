<view class="container">
  <view class="card">
    <view class="title">动作库</view>
    <view class="subtitle">内置常用动作，可后续导入 exercises-dataset 完整库</view>
    <input class="input search" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索动作、中文名、目标肌群" />
    <scroll-view scroll-x="true" class="h-scroll">
      <view class="filter-row">
        <view class="chip {{!bodyPart ? 'active' : ''}}" data-value="" bindtap="selectBodyPart">全部部位</view>
        <view wx:for="{{bodyPartOptions}}" wx:key="value" class="chip {{item.selected ? 'active' : ''}}" data-value="{{item.value}}" bindtap="selectBodyPart">{{item.label}}</view>
      </view>
    </scroll-view>
    <scroll-view scroll-x="true" class="h-scroll">
      <view class="filter-row">
        <view class="chip {{!equipment ? 'active' : ''}}" data-value="" bindtap="selectEquipment">全部器材</view>
        <view wx:for="{{equipmentOptions}}" wx:key="value" class="chip {{item.selected ? 'active' : ''}}" data-value="{{item.value}}" bindtap="selectEquipment">{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <empty-state wx:if="{{items.length === 0}}" title="没找到动作" desc="换个搜索词或清空筛选" />
  <view wx:for="{{items}}" wx:key="_id" class="card exercise-card" data-id="{{item._id}}" bindtap="showDetail">
    <view class="row between">
      <view>
        <view class="exercise-name">{{item.display_name}}</view>
        <view class="exercise-en">{{item.name}}</view>
      </view>
      <view class="tag">{{item.display_equipment}}</view>
    </view>
    <view class="meta">{{item.display_body_part}} · {{item.target}}</view>
    <view class="steps" wx:if="{{item.first_step}}">{{item.first_step}}</view>
  </view>
</view>
