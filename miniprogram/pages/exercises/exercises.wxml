<view class="container">
  <view class="card library-head">
    <view class="title">动作库</view>
    <view class="subtitle">1324 个动作，向下滚动继续加载</view>
    <input class="input search" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索动作、肌群或英文名" />
    <scroll-view scroll-x="true" class="h-scroll">
      <view class="filter-row">
        <view class="chip {{!bodyPart ? 'active' : ''}}" data-value="" bindtap="selectBodyPart">全部部位</view>
        <view wx:for="{{bodyPartOptions}}" wx:key="*this" class="chip {{bodyPart === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectBodyPart">{{item}}</view>
      </view>
    </scroll-view>
    <scroll-view scroll-x="true" class="h-scroll">
      <view class="filter-row">
        <view class="chip {{!equipment ? 'active' : ''}}" data-value="" bindtap="selectEquipment">全部器材</view>
        <view wx:for="{{equipmentOptions}}" wx:key="*this" class="chip {{equipment === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectEquipment">{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <empty-state wx:if="{{items.length === 0 && !isLoading}}" title="没找到动作" desc="换个搜索词或清空筛选" />
  <view wx:for="{{items}}" wx:key="_id" class="card exercise-card" data-id="{{item._id}}" bindtap="showDetail">
    <image wx:if="{{item.image_url}}" class="exercise-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="true" />
    <view class="exercise-body">
      <view class="exercise-name">{{item.display_name}}</view>
      <view class="exercise-en">{{item.name}}</view>
      <view class="meta">{{item.display_body_part}} · {{item.display_equipment}} · {{item.target_zh || item.target}}</view>
      <view class="steps" wx:if="{{item.first_step}}">{{item.first_step}}</view>
      <view class="attribution" wx:if="{{item.attribution}}">{{item.attribution}}</view>
    </view>
  </view>
  <view class="loading-more" wx:if="{{isLoading}}">正在加载动作...</view>
  <view class="loading-more" wx:elif="{{items.length > 0 && !hasMore}}">已经到底了</view>
</view>
