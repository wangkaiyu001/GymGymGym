<view class="container">
  <view class="card hero">
    <view class="title">训练复盘</view>
    <view class="subtitle">只看最近有没有在练，以及真正突破了什么</view>
  </view>

  <view class="card">
    <view class="section-title">近期训练摘要</view>
    <view class="period-list">
      <view wx:for="{{periodSummary}}" wx:key="key" class="period-card">
        <view class="period-label">{{item.label}}</view>
        <view class="period-main">{{item.sessions}} 次训练</view>
        <view class="period-grid">
          <view><text>{{item.sets}}</text><view>有效组</view></view>
          <view><text>{{item.reps}}</text><view>总次数</view></view>
          <view><text>{{item.volume}}</text><view>容量 kg</view></view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">近期 PR</view>
    <empty-state wx:if="{{prHighlights.length === 0}}" title="还没有 PR" desc="完成几次带重量的训练后，这里会出现突破" />
    <view wx:for="{{prHighlights}}" wx:key="_id" class="pr-row">
      <view class="pr-rank">{{index + 1}}</view>
      <view class="pr-content">
        <view class="row between">
          <view class="stat-name">{{item.display_name}}</view>
          <view class="pr-score">{{item.pr_metric}}</view>
        </view>
        <view class="stat-meta">{{item.pr_subtitle}} · 最近 {{item.display_last_performed}}</view>
      </view>
    </view>
  </view>
</view>
