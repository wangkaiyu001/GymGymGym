.hero { background: #101828; color: #fff; }
.hero .title, .hero .subtitle { color: #fff; }
.period-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; }
.period-card { background: #f8fafc; border-radius: 22rpx; padding: 22rpx; }
.period-label { font-size: 24rpx; color: #667085; }
.period-main { margin-top: 8rpx; font-size: 34rpx; font-weight: 800; }
.period-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8rpx; margin-top: 18rpx; color: #667085; font-size: 21rpx; }
.period-grid text { display: block; color: #101828; font-size: 27rpx; font-weight: 800; margin-bottom: 4rpx; }
.pr-row { display: flex; gap: 18rpx; padding: 22rpx 0; border-top: 1rpx solid #eaecf0; }
.pr-rank { width: 46rpx; height: 46rpx; border-radius: 50%; background: #e8f0ff; color: #1d4ed8; display: flex; align-items: center; justify-content: center; font-weight: 800; }
.pr-content { flex: 1; min-width: 0; }
.stat-name { font-size: 30rpx; font-weight: 800; }
.stat-meta { color: #667085; font-size: 24rpx; margin-top: 8rpx; }
.pr-score { color: #2563eb; font-size: 25rpx; font-weight: 800; margin-left: 12rpx; }
