<view class="container">
  <view class="card hero">
    <view class="title">我的习惯</view>
    <view class="subtitle">只保留生成训练计划真正需要的信息</view>
  </view>

  <view class="card">
    <view class="field">
      <view class="label">昵称</view>
      <input class="input" value="{{profile.nickname}}" data-key="nickname" bindinput="onInput" placeholder="怎么称呼你" />
    </view>
    <view class="field">
      <view class="label">训练经验</view>
      <picker range="{{levelLabels}}" value="{{levelIndex}}" bindchange="onLevelChange">
        <view class="picker-like">{{levelLabels[levelIndex]}}</view>
      </picker>
    </view>
    <view class="field two-col">
      <view>
        <view class="label">主要目标</view>
        <picker range="{{goalLabels}}" value="{{goalIndex}}" bindchange="onGoalChange">
          <view class="picker-like">{{goalLabels[goalIndex]}}</view>
        </picker>
      </view>
      <view>
        <view class="label">常用场地</view>
        <picker range="{{locationLabels}}" value="{{locationIndex}}" bindchange="onLocationChange">
          <view class="picker-like">{{locationLabels[locationIndex]}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <view class="label">常用器材</view>
      <view class="chip-list">
        <view wx:for="{{equipmentOptions}}" wx:key="value" class="chip {{item.selected ? 'active' : ''}}" data-value="{{item.value}}" bindtap="toggleEquipment">{{item.label}}</view>
      </view>
    </view>
    <view class="field">
      <view class="label">一句话习惯</view>
      <textarea class="textarea" value="{{profile.goal_note}}" data-key="goal_note" bindinput="onInput" placeholder="例如：每周三练，动作不要太复杂；膝盖偶尔不舒服" />
    </view>
    <button class="btn btn-primary" loading="{{isSaving}}" disabled="{{isSaving}}" bindtap="save">保存基础档案</button>
  </view>
</view>
