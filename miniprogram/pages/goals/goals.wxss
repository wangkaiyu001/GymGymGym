.hero { background: linear-gradient(135deg, #7c2d12, #f97316); color: #fff; }
.hero .title, .hero .subtitle { color: #fff; }
.goal-hint { margin: -8rpx 0 24rpx; }
.form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.form-grid .field { min-width: 0; }
.count-pill { min-width: 44rpx; height: 44rpx; padding: 0 12rpx; border-radius: 999rpx; background: #fff1e8; color: #c2410c; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 800; }
.done-count { background: #ecfdf3; color: #067647; }
.goal-card { border-top: 1rpx solid #eaecf0; padding: 24rpx 0; }
.goal-card:first-of-type { border-top: 0; }
.goal-card-done { opacity: 0.78; }
.goal-heading { align-items: flex-start; gap: 16rpx; }
.goal-title { font-size: 30rpx; font-weight: 800; color: #101828; }
.goal-type { margin-top: 6rpx; color: #667085; font-size: 24rpx; }
.status { flex: none; border-radius: 999rpx; padding: 8rpx 14rpx; font-size: 22rpx; font-weight: 700; }
.status.active { background: #fff1e8; color: #c2410c; }
.status.done { background: #ecfdf3; color: #067647; }
.goal-metric { margin-top: 16rpx; padding: 18rpx; border-radius: 18rpx; background: #fff8f3; color: #7c2d12; font-size: 24rpx; }
.goal-metric text { float: right; color: #c2410c; font-size: 30rpx; font-weight: 800; }
.goal-meta { margin-top: 12rpx; color: #475467; font-size: 24rpx; }
.goal-desc { margin-top: 14rpx; color: #344054; line-height: 1.6; }
.goal-actions { display: flex; gap: 14rpx; margin-top: 20rpx; }
.goal-action { flex: 1; min-height: 60rpx; line-height: 60rpx; margin: 0; border: 0; border-radius: 999rpx; font-size: 24rpx; font-weight: 700; }
.goal-action.done { background: #fff1e8; color: #c2410c; }
.goal-action.restore { background: #ecfdf3; color: #067647; }
.goal-action.delete { background: #f2f4f7; color: #667085; }
