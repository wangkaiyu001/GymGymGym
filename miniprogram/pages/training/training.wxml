<view class="container">
  <view class="hero card compact-hero">
    <view class="title">{{mode === 'training' ? '训练进行中' : '今天怎么练'}}</view>
    <view class="subtitle">{{mode === 'training' ? planDate + ' · 直接修改实际完成情况' : '给你一套可以直接开始的计划'}}</view>
  </view>

  <view wx:if="{{bodyPartReminders.length > 0}}" class="card reminder-card">
    <view class="section-title">部位训练间隔</view>
    <view class="reminder-list">
      <view wx:for="{{bodyPartReminders}}" wx:key="part" class="reminder-item {{item.state}}">
        <view class="reminder-part">{{item.part}}</view>
        <view class="reminder-hint">{{item.hint}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{cloudError}}" class="card cloud-error">
    <view class="section-title">云开发尚未连通</view>
    <view class="muted">请先在 CloudBase 环境设置 → 安全配置 → 小程序关联中添加当前 AppID。</view>
  </view>

  <view wx:if="{{mode === 'planning'}}" class="card generator-card">
    <view class="section-title">告诉我今天的情况</view>
    <textarea class="prompt-input" value="{{prompt}}" bindinput="onPromptInput" placeholder="例如：今天练胸和肩，只有哑铃，状态不错，45分钟；或者今天很累，想轻松练腿" />
    <view class="planning-row">
      <picker mode="date" value="{{planDate}}" bindchange="onDateChange">
        <view class="date-picker">训练日期：{{planDate}}</view>
      </picker>
      <button class="small-btn ghost" loading="{{isGenerating}}" bindtap="generatePlan">重新生成</button>
    </view>
  </view>

  <view class="card plan-card" wx:if="{{blocks.length > 0}}">
    <view class="row between plan-head">
      <view>
        <view class="section-title">{{mode === 'training' ? '记录实际训练' : '推荐训练计划'}}</view>
        <view class="muted">{{blocks.length}} 个动作 · 重量参考上次表现，没有历史则从轻开始</view>
      </view>
      <button wx:if="{{mode === 'training'}}" class="small-btn ghost" bindtap="collapsePlan">调整计划</button>
    </view>

    <view wx:for="{{blocks}}" wx:key="local_id" class="workout-block">
      <view class="row between block-head">
        <view>
          <view class="block-title">{{index + 1}}. {{item.title}}</view>
          <view class="block-meta">{{item.plan_reason || '按计划完成，重量可现场修改'}}</view>
        </view>
        <button class="small-btn danger" data-index="{{item.block_index}}" bindtap="deleteBlock">移除</button>
      </view>
      <view wx:for="{{item.sets}}" wx:for-item="set" wx:key="local_id" class="set-line">
        <view class="set-number">{{set.set_index_local + 1}}</view>
        <view class="set-inputs">
          <input class="set-input" type="digit" value="{{set.weight_kg}}" data-block-index="{{set.block_index}}" data-set-index="{{set.set_index_local}}" data-key="weight_kg" bindinput="onSetInput" />
          <text>kg</text>
          <input class="set-input" type="number" value="{{set.reps}}" data-block-index="{{set.block_index}}" data-set-index="{{set.set_index_local}}" data-key="reps" bindinput="onSetInput" />
          <text>次</text>
          <input class="set-input small" type="digit" value="{{set.rpe}}" data-block-index="{{set.block_index}}" data-set-index="{{set.set_index_local}}" data-key="rpe" bindinput="onSetInput" />
          <text>RPE</text>
        </view>
      </view>
      <button class="add-set-btn" data-index="{{item.block_index}}" bindtap="addRound">+ 加一组</button>
    </view>

    <view class="workout-actions">
      <button wx:if="{{mode === 'planning'}}" class="btn btn-primary" bindtap="startWorkout">开始训练</button>
      <block wx:else>
        <button class="btn btn-danger" bindtap="discardWorkout">放弃</button>
        <button class="btn btn-primary" loading="{{isSaving}}" disabled="{{isSaving}}" bindtap="saveWorkout">完成并保存</button>
      </block>
    </view>
  </view>

  <view class="card recent-card">
    <view class="row between">
      <view class="section-title">最近训练</view>
      <view class="muted">也可以补录过去日期</view>
    </view>
    <empty-state wx:if="{{recentSessions.length === 0}}" title="还没有训练记录" desc="完成第一次训练后会出现在这里" />
    <view wx:for="{{recentSessions}}" wx:key="_id" class="session-row" data-id="{{item._id}}" bindtap="goSessionDetail">
      <view><view class="session-title">{{item.title}}</view><view class="session-meta">{{item.date}}</view></view>
      <view class="arrow">›</view>
    </view>
  </view>
</view>
