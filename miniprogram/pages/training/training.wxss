.hero { background: linear-gradient(135deg, #111827, #2563eb); color: #fff; }
.hero .title, .hero .subtitle { color: #fff; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.mini-actions { display: flex; gap: 12rpx; }
.superset-size-picker { flex: none; }
.small-btn.size-btn { background: #fff7ed; color: #c2410c; }
.small-btn {
  min-height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  background: #e8f0ff;
  color: #1d4ed8;
  border: 0;
}
.small-btn.ghost { background: #f2f4f7; color: #344054; }
.small-btn.danger { background: #fff1f3; color: #c01048; }
.recommend-box {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}
.recommend-title { font-size: 28rpx; font-weight: 800; color: #101828; }
.recommend-desc { margin-top: 6rpx; color: #667085; font-size: 22rpx; }
.recommend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #eaecf0;
}
.recommend-name { font-size: 28rpx; font-weight: 800; }
.recommend-meta { margin-top: 6rpx; color: #475467; font-size: 23rpx; }
.recommend-reason { margin-top: 6rpx; color: #1d4ed8; font-size: 22rpx; }
.block {
  padding: 22rpx 0;
  border-top: 1rpx solid #eaecf0;
}
.block-title { font-size: 30rpx; font-weight: 800; }
.block-meta { font-size: 24rpx; color: #667085; margin-top: 6rpx; }
.set-line {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 18rpx;
  margin-top: 16rpx;
}
.set-name { font-size: 26rpx; font-weight: 700; margin-bottom: 14rpx; }
.set-inputs { display: flex; align-items: center; gap: 8rpx; color: #667085; font-size: 22rpx; }
.set-input {
  width: 112rpx;
  height: 62rpx;
  background: #fff;
  border-radius: 14rpx;
  text-align: center;
}
.set-input.small { width: 88rpx; }
.set-flags { gap: 12rpx; margin-top: 14rpx; }
.flag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #667085;
  font-size: 22rpx;
}
.flag.active { background: #101828; color: #fff; }
.flag.danger { color: #c01048; }
.finish { margin-top: 22rpx; }
.recent-head { align-items: flex-start; }
.recent-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
}
.recent-filter-list { margin: 18rpx 0 4rpx; }
.recent-filter {
  background: #f2f4f7;
  color: #344054;
}
.recent-filter.active {
  background: #101828;
  color: #fff;
}
.recent-filter.disabled { opacity: 0.48; }
.session-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-top: 1rpx solid #eaecf0;
}
.session-title { font-weight: 700; }
.session-meta { font-size: 24rpx; color: #667085; margin-top: 8rpx; }
.session-match {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ecfdf3;
  color: #027a48;
  font-size: 21rpx;
}
.arrow { font-size: 40rpx; color: #98a2b3; }
