.note { margin-top: 20rpx; color: #475467; line-height: 1.6; }
.block-title { font-size: 32rpx; font-weight: 800; }
.block-meta { color: #667085; font-size: 24rpx; margin-top: 8rpx; }
.set-row {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #eaecf0;
  font-size: 25rpx;
}
.set-value { text-align: right; font-weight: 800; color: #2563eb; }
