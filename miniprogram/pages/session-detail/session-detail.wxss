.note { margin-top: 20rpx; color: #475467; line-height: 1.6; }
.block-head { align-items: flex-start; }
.block-title { font-size: 32rpx; font-weight: 800; }
.block-meta { color: #667085; font-size: 24rpx; margin-top: 8rpx; }
.set-row {
  padding: 20rpx 0;
  border-top: 1rpx solid #eaecf0;
  font-size: 25rpx;
}
.set-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}
.set-name { font-weight: 800; color: #101828; }
.set-actions { display: flex; gap: 10rpx; }
.small-btn {
  min-height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  padding: 0 18rpx;
  font-size: 23rpx;
  border: 0;
}
.small-btn.ghost { background: #eef4ff; color: #1d4ed8; }
.small-btn.danger { background: #fff1f3; color: #c01048; }
.set-inputs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #667085;
  font-size: 22rpx;
  margin-top: 16rpx;
}
.set-input {
  width: 112rpx;
  height: 62rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  text-align: center;
  font-weight: 800;
  color: #2563eb;
}
.set-input.small { width: 88rpx; }
.flag-row { display: flex; gap: 12rpx; margin-top: 14rpx; }
.flag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 22rpx;
}
.flag.active { background: #101828; color: #fff; }
